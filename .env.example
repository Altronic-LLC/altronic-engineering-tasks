# -----------------------------------------------------------------------------
# Altronic Engineering Task System — environment configuration
#
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored, so secrets and tenant-specific identifiers stay out of source.
# -----------------------------------------------------------------------------

# Set to "true" to use mock data (no auth required, no network calls).
# Set to "false" to use the real Microsoft Graph API.
VITE_USE_MOCK=true

# -----------------------------------------------------------------------------
# Entra ID (Azure AD) — required when VITE_USE_MOCK=false
# -----------------------------------------------------------------------------

# Application (client) ID from the app registration. Comes from your admin
# after they create the SPA app registration in Entra ID.
VITE_AZURE_CLIENT_ID=PASTE_CLIENT_ID_HERE

# Directory (tenant) ID — already confirmed:
VITE_AZURE_TENANT_ID=bde86e02-c641-4952-97f2-99ea6d9b8e29

# -----------------------------------------------------------------------------
# SharePoint identifiers — confirmed via PowerShell discovery
# -----------------------------------------------------------------------------

# Site: /sites/Altronic_Engineering
VITE_SP_SITE_ID=coopermachineryservices.sharepoint.com,ddb5fc80-ea51-4d56-b008-ce6a82af49b0,aa6b9467-3f57-4213-bbd4-60b94403421a

# List: "Project Task List"
VITE_SP_LIST_ID=42fb8c19-5f33-4fdd-9ef7-df6f21433588

# Parent Projects list (lookup target for Parent_x0020_Project_x0020_Refer).
# TODO: run the lookup-discovery PowerShell snippet from CLAUDE.md and paste
# the resulting list ID here. Until then, parent project names will fall back
# to showing just the lookup ID.
VITE_SP_PROJECTS_LIST_ID=

# Test Results list on the same Altronic Engineering site. Drives the
# Test Sheets view and the "Create Test Sheet" button on tasks. Leave blank
# in mock mode (mock data ships with the app).
VITE_SP_TEST_RESULTS_LIST_ID=

# Email address of the shared mailbox the app sends @-mention notifications
# FROM. Each user who can post comments must have Send-As permission on this
# mailbox in Exchange (Exchange admin centre → Mailbox → Delegation).
# Requires the Mail.Send.Shared Graph scope (admin consent). Leave blank to
# disable email — the app then logs notifications to the console.
VITE_SHARED_MAILBOX=
